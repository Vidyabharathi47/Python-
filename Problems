###Check prime or not

n=int(input("Enter the number"))
i=2
while i<n:     ## 2 la irundhu n-1 varakum check pannu
    if n%1==0:   ##divide ana not prime
        print('This is not a Prime')  
        break  ##answer got so break
    i=i+1      ##increments the value of i by 1 in each iteration
else:                      ###no elif after while condition
  if n>1:
    print("prime")
  else:
    print('Not a prime')

